# ========================================
# デザイン関連ファイル（Adobe Creative Cloud等で管理）
# ========================================
デザイン関連/

# Adobe系ファイル（念のため個別指定）
*.ai
*.psd
*.indd
*.xd

# 高解像度画像（元素材）
*.tif
*.tiff
*.eps
*.raw

# Office系（クライアント指示書など）
*.pptx
*.xlsx
*.docx

# ========================================
# OS生成ファイル
# ========================================
.DS_Store
Thumbs.db
desktop.ini

# Officeテンポラリ
~$*

# ========================================
# ローカル専用ドキュメント
# ========================================
..local-docs/
.Client-instructions/

# ========================================
# バックアップファイル
# ========================================
-*

# ========================================
# エディタ・IDE
# ========================================
.vscode/
*.code-workspace
.idea/

# ========================================
# Node.js（将来ビルド環境使う場合）
# ========================================
node_modules/
dist/
.cache/

# ========================================
# SCSS コンパイル生成物
# ========================================
# ソースマップは開発時のみ使用（本番不要）
css/*.map
